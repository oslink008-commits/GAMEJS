<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>JS Terminal</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&display=swap');

  :root {
    --bg:        #111110;
    --surface:   #181816;
    --border:    #2a2925;
    --text:      #e8e4dc;
    --text-dim:  #8a8680;
    --text-faint:#2e2c28;
    --amber:     #c4732a;
    --amber-lite:#d4894a;
    --amber-dim: #7a3f10;
    --amber-bg:  #c4732a18;
    --result:    #ccc8bf;
    --error:     #c46a4a;
    --log:       #8fafc4;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13.5px;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Title bar ─────────────────────────── */
  #titlebar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0;
  }
  .dot { width: 9px; height: 9px; border-radius: 50%; }
  .dot.r { background: #7a3028; }
  .dot.y { background: #7a5a1a; }
  .dot.g { background: #305828; }
  #titlebar .title {
    color: var(--text-dim);
    font-size: 11.5px;
    font-weight: 300;
    letter-spacing: 0.1em;
    margin-left: 8px;
  }
  #titlebar .ver {
    margin-left: auto;
    font-size: 10px;
    color: var(--border);
    letter-spacing: 0.05em;
  }

  /* ── History chips ─────────────────────── */
  #history-bar {
    display: flex;
    gap: 5px;
    overflow-x: auto;
    padding: 7px 16px 0;
    flex-shrink: 0;
    scrollbar-width: none;
  }
  #history-bar:empty { display: none; }
  #history-bar::-webkit-scrollbar { display: none; }
  .hist-chip {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: inherit;
    font-size: 10.5px;
    padding: 3px 10px;
    border-radius: 3px;
    white-space: nowrap;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.12s, color 0.12s;
  }
  .hist-chip:active { border-color: var(--amber-dim); color: var(--amber-lite); }

  /* ── Output area ───────────────────────── */
  #output {
    flex: 1;
    overflow-y: auto;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    scroll-behavior: smooth;
  }

  #welcome {
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 300;
    line-height: 1.9;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
  }
  #welcome .label { color: var(--amber); font-weight: 500; }
  #welcome code {
    color: var(--text);
    background: #1e1c19;
    padding: 1px 6px;
    border-radius: 3px;
  }

  .line {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 9px 0;
    border-bottom: 1px solid var(--text-faint);
    animation: fadein 0.15s ease;
  }
  @keyframes fadein {
    from { opacity: 0; transform: translateY(3px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cmd {
    color: var(--text);
    word-break: break-all;
    display: flex;
    gap: 9px;
    align-items: flex-start;
  }
  .cmd .arrow { color: var(--amber); flex-shrink: 0; font-size: 15px; line-height: 1.3; }

  .result {
    color: var(--result);
    padding-left: 20px;
    word-break: break-all;
    white-space: pre-wrap;
    line-height: 1.55;
    font-weight: 300;
  }
  .result.error { color: var(--error); }
  .result.log   { color: var(--log); }
  .result .tag  { color: var(--text-dim); margin-right: 4px; font-size: 11px; }

  /* ── Input bar ─────────────────────────── */
  #inputbar {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 10px 14px;
    display: flex;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  #prompt {
    color: var(--amber);
    font-size: 16px;
    flex-shrink: 0;
    padding-bottom: 6px;
    line-height: 1;
  }

  #code-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13.5px;
    resize: none;
    min-height: 34px;
    max-height: 130px;
    line-height: 1.6;
    caret-color: var(--amber);
    overflow-y: auto;
    font-weight: 400;
  }
  #code-input::placeholder { color: var(--border); }

  #run-btn {
    background: var(--amber-bg);
    border: 1px solid var(--amber-dim);
    color: var(--amber-lite);
    font-family: inherit;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 7px 15px;
    border-radius: 5px;
    cursor: pointer;
    flex-shrink: 0;
    align-self: flex-end;
    transition: background 0.12s, border-color 0.12s;
  }
  #run-btn:active {
    background: #c4732a30;
    border-color: var(--amber);
    color: var(--amber);
  }

  #clear-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: inherit;
    font-size: 11px;
    padding: 6px 10px;
    border-radius: 5px;
    cursor: pointer;
    flex-shrink: 0;
    align-self: flex-end;
    transition: border-color 0.12s, color 0.12s;
  }
  #clear-btn:active { border-color: var(--error); color: var(--error); }
</style>
</head>
<body>

<div id="titlebar">
  <div class="dot r"></div>
  <div class="dot y"></div>
  <div class="dot g"></div>
  <span class="title">JS TERMINAL</span>
  <span class="ver">v1.0</span>
</div>

<div id="history-bar"></div>

<div id="output">
  <div id="welcome">
    <span class="label">JS Terminal</span> — runs in Chrome, no install needed.<br>
    Type JavaScript → tap <span class="label">RUN</span> or press <span class="label">Enter</span><br>
    <span style="color:var(--border)">Shift+Enter for new line &nbsp;·&nbsp; tap history to recall</span><br><br>
    Try: <code>2 ** 10</code> &nbsp; <code>new Date()</code> &nbsp; <code>[1,2,3].map(x=>x*x)</code>
  </div>
</div>

<div id="inputbar">
  <span id="prompt">›</span>
  <textarea
    id="code-input"
    placeholder="Enter JavaScript..."
    rows="1"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
    spellcheck="false"
  ></textarea>
  <button id="clear-btn" onclick="clearOutput()">CLR</button>
  <button id="run-btn" onclick="runCode()">RUN ▶</button>
</div>

<script>
  const outputEl  = document.getElementById('output');
  const inputEl   = document.getElementById('code-input');
  const histBarEl = document.getElementById('history-bar');
  let cmdHistory  = [];

  // ── Auto-resize textarea ──────────────────
  inputEl.addEventListener('input', autoResize);
  function autoResize() {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 130) + 'px';
  }

  // ── Enter = run / Shift+Enter = newline ───
  inputEl.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      runCode();
    }
  });

  // ── Execute ───────────────────────────────
  function runCode() {
    const code = inputEl.value.trim();
    if (!code) return;

    // History
    if (cmdHistory[cmdHistory.length - 1] !== code) {
      cmdHistory.push(code);
      if (cmdHistory.length > 14) cmdHistory.shift();
      renderHistory();
    }

    // Patch console
    const logs = [];
    const patch = (type, orig) => (...args) => {
      logs.push({ type, text: args.map(stringify).join(' ') });
      orig(...args);
    };
    const origLog   = console.log;
    const origWarn  = console.warn;
    const origError = console.error;
    console.log   = patch('log',   origLog);
    console.warn  = patch('log',   origWarn);
    console.error = patch('error', origError);

    let result, isError = false;
    try   { result = eval(code); }
    catch (e) { result = e.message; isError = true; }

    console.log   = origLog;
    console.warn  = origWarn;
    console.error = origError;

    // Build output line
    const line = document.createElement('div');
    line.className = 'line';

    // Command
    const cmdEl = document.createElement('div');
    cmdEl.className = 'cmd';
    cmdEl.innerHTML = `<span class="arrow">›</span><span>${escHtml(code)}</span>`;
    line.appendChild(cmdEl);

    // Console logs
    logs.forEach(({ type, text }) => {
      const el = document.createElement('div');
      el.className = 'result ' + type;
      el.innerHTML = `<span class="tag">${type === 'error' ? 'err' : 'log'}</span>${escHtml(text)}`;
      line.appendChild(el);
    });

    // Return value
    if (result !== undefined || logs.length === 0) {
      const resEl = document.createElement('div');
      resEl.className = 'result' + (isError ? ' error' : '');
      const prefix = isError ? '✖ ' : '← ';
      resEl.innerHTML = `<span class="tag">${isError ? 'err' : 'out'}</span>${escHtml(prefix + stringify(result))}`;
      line.appendChild(resEl);
    }

    outputEl.appendChild(line);
    outputEl.scrollTop = outputEl.scrollHeight;

    inputEl.value = '';
    autoResize();
    inputEl.focus();
  }

  // ── Helpers ───────────────────────────────
  function stringify(val) {
    if (val === null)      return 'null';
    if (val === undefined) return 'undefined';
    if (typeof val === 'function') return val.toString();
    if (typeof val === 'object') {
      try { return JSON.stringify(val, null, 2); } catch { return String(val); }
    }
    return String(val);
  }

  function escHtml(str) {
    return String(str)
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;');
  }

  function clearOutput() {
    outputEl.innerHTML = '<div style="color:var(--border);font-size:12px;padding:8px 0;">Cleared.</div>';
  }

  function renderHistory() {
    histBarEl.innerHTML = '';
    [...cmdHistory].reverse().forEach(cmd => {
      const chip = document.createElement('button');
      chip.className   = 'hist-chip';
      chip.textContent = cmd.length > 28 ? cmd.slice(0, 26) + '…' : cmd;
      chip.onclick = () => {
        inputEl.value = cmd;
        autoResize();
        inputEl.focus();
      };
      histBarEl.appendChild(chip);
    });
  }

  outputEl.addEventListener('click', () => inputEl.focus());
  inputEl.focus();
</script>
</body>
</html>
