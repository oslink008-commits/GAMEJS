<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Snake</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Nunito:wght@700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0b0c10;--surface:#12141a;--card:#181b24;--border:#1e2030;
  --green:#69ff47;--green2:#40cc20;--text:#e8eaf0;--dim:#6b7280;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{
  width:100%;height:100%;overflow:hidden;
  background:var(--bg);color:var(--text);
  font-family:'Nunito',sans-serif;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  user-select:none;-webkit-user-select:none;
  touch-action:none;
}

/* â”€â”€ TOP â”€â”€ */
#top{
  width:100%;max-width:400px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 4px 10px;
}
#title{
  font-family:'Orbitron',monospace;
  font-size:22px;font-weight:900;
  color:var(--green);
  text-shadow:0 0 18px #69ff4766;
  letter-spacing:.04em;
}
#scores{display:flex;gap:8px;}
.sbox{
  background:var(--surface);border:1px solid var(--border);
  border-radius:8px;padding:5px 12px;
  display:flex;flex-direction:column;align-items:center;min-width:58px;
}
.slabel{font-size:9px;font-weight:800;letter-spacing:.12em;color:var(--dim);}
.sval{font-size:17px;font-weight:900;color:var(--text);line-height:1.2;}

/* â”€â”€ CANVAS â”€â”€ */
#cv{
  display:block;border-radius:14px;
  border:1px solid var(--border);
  background:#0d0f16;
  touch-action:none;
}

/* â”€â”€ CONTROLS â”€â”€ */
#controls{
  display:flex;flex-direction:column;
  align-items:center;gap:4px;margin-top:12px;
}
.ctrl-row{display:flex;gap:4px;}
.cbtn{
  width:48px;height:48px;
  background:var(--surface);border:1px solid var(--border);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;cursor:pointer;
  transition:background .1s,border-color .1s;
  -webkit-tap-highlight-color:transparent;
}
.cbtn:active{background:#69ff4720;border-color:var(--green);}

/* â”€â”€ OVERLAY â”€â”€ */
#overlay{
  display:none;position:absolute;
  inset:0;border-radius:14px;
  background:#0b0c10e8;backdrop-filter:blur(6px);
  flex-direction:column;align-items:center;justify-content:center;
  gap:12px;z-index:10;
}
#overlay.show{display:flex;}
#ov-emoji{font-size:52px;}
#ov-title{
  font-family:'Orbitron',monospace;
  font-size:22px;font-weight:900;
  letter-spacing:.06em;
}
#ov-sub{font-size:13px;color:var(--dim);font-weight:700;}
#ov-score{font-size:16px;font-weight:900;color:var(--green);}
#ov-btn{
  background:var(--green);color:#0b0c10;
  border:none;border-radius:10px;
  font-family:inherit;font-size:14px;font-weight:900;
  padding:12px 34px;cursor:pointer;margin-top:4px;
  letter-spacing:.04em;
}
#ov-btn:active{background:#90ff60;}

/* level badge */
#lvl-badge{
  position:absolute;top:10px;left:10px;
  background:#69ff4720;border:1px solid #69ff4740;
  color:var(--green);font-size:10px;font-weight:800;
  letter-spacing:.1em;padding:3px 9px;border-radius:6px;
  pointer-events:none;
}
</style>
</head>
<body>

<div id="top">
  <div id="title">SNAKE</div>
  <div id="scores">
    <div class="sbox"><div class="slabel">SCORE</div><div class="sval" id="sc">0</div></div>
    <div class="sbox"><div class="slabel">BEST</div><div class="sval" id="hi">0</div></div>
  </div>
</div>

<div style="position:relative">
  <canvas id="cv"></canvas>
  <div id="lvl-badge" style="display:none">LVL <span id="lvl-num">1</span></div>
  <div id="overlay">
    <div id="ov-emoji">đŸ</div>
    <div id="ov-title" style="color:#69ff47">SNAKE</div>
    <div id="ov-sub">Swipe or use D-pad to move</div>
    <div id="ov-score"></div>
    <button id="ov-btn" onclick="startGame()">â–¶ START</button>
  </div>
</div>

<div id="controls">
  <div class="ctrl-row">
    <div class="cbtn" onclick="setDir(0,-1)">â–²</div>
  </div>
  <div class="ctrl-row">
    <div class="cbtn" onclick="setDir(-1,0)">â—€</div>
    <div class="cbtn" style="background:#69ff4715;border-color:#69ff4730" onclick="setDir(0,0)">â—</div>
    <div class="cbtn" onclick="setDir(1,0)">â–¶</div>
  </div>
  <div class="ctrl-row">
    <div class="cbtn" onclick="setDir(0,1)">â–¼</div>
  </div>
</div>

<script>
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  SETUP
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
const cv  = document.getElementById('cv');
const ctx = cv.getContext('2d');

const COLS = 20, ROWS = 20;
const SZ   = Math.min(Math.floor((window.innerWidth - 20) / COLS), 22);
cv.width   = SZ * COLS;
cv.height  = SZ * ROWS;

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  STATE
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
let snake, dir, nextDir, food, bonus, score, best, level;
let gameLoop, state; // 'idle'|'playing'|'dead'
let frame = 0;
let particles = [];

function startGame() {
  snake   = [{x:10,y:10},{x:9,y:10},{x:8,y:10}];
  dir     = {x:1,y:0};
  nextDir = {x:1,y:0};
  score   = 0;
  level   = 1;
  best    = parseInt(localStorage.getItem('snake_best')||'0');
  particles = [];
  bonus   = null;
  bonusTimer = 0;
  state   = 'playing';
  document.getElementById('overlay').classList.remove('show');
  document.getElementById('lvl-badge').style.display = 'block';
  placeFood();
  clearInterval(gameLoop);
  gameLoop = setInterval(tick, getSpeed());
  render();
}

function getSpeed() {
  return Math.max(60, 160 - (level-1)*18);
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  FOOD
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
const FOODS = ['đŸ','đŸ','đŸ‡','đŸ“','đŸ‰','đŸ‹','đŸ¥','đŸ‘'];
let foodEmoji = 'đŸ';
let bonusTimer = 0;

function placeFood() {
  const empty = [];
  for(let x=0;x<COLS;x++) for(let y=0;y<ROWS;y++){
    if(!snake.some(s=>s.x===x&&s.y===y)) empty.push({x,y});
  }
  const f = empty[Math.floor(Math.random()*empty.length)];
  food = f;
  foodEmoji = FOODS[Math.floor(Math.random()*FOODS.length)];
}

function placeBonus() {
  const empty = [];
  for(let x=0;x<COLS;x++) for(let y=0;y<ROWS;y++){
    if(!snake.some(s=>s.x===x&&s.y===y) && !(food.x===x&&food.y===y)) empty.push({x,y});
  }
  const f = empty[Math.floor(Math.random()*empty.length)];
  bonus = f;
  bonusTimer = 50; // disappears after 50 ticks
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  GAME TICK
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function tick() {
  dir = {...nextDir};
  const head = {x:snake[0].x+dir.x, y:snake[0].y+dir.y};

  // Wall collision
  if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS){
    die(); return;
  }
  // Self collision
  if(snake.some(s=>s.x===head.x&&s.y===head.y)){
    die(); return;
  }

  snake.unshift(head);

  // Eat food
  if(head.x===food.x&&head.y===food.y){
    score += level * 10;
    spawnParticles(food.x,food.y,'#69ff47');
    placeFood();
    updateScore();
    // Level up every 5 foods
    if(score>=level*50){
      level++;
      document.getElementById('lvl-num').textContent=level;
      clearInterval(gameLoop);
      gameLoop=setInterval(tick,getSpeed());
    }
    // Spawn bonus occasionally
    if(Math.random()<0.25 && !bonus) placeBonus();
  } else if(bonus && head.x===bonus.x&&head.y===bonus.y){
    score += level * 30;
    spawnParticles(bonus.x,bonus.y,'#ffd740');
    bonus = null;
    updateScore();
  } else {
    snake.pop();
  }

  // Bonus timer
  if(bonus){
    bonusTimer--;
    if(bonusTimer<=0) bonus=null;
  }

  frame++;
  render();
}

function die() {
  clearInterval(gameLoop);
  state='dead';
  spawnParticles(snake[0].x,snake[0].y,'#ff4444',16);
  if(score>best){ best=score; localStorage.setItem('snake_best',best); }
  render();
  setTimeout(()=>{
    document.getElementById('ov-emoji').textContent='đŸ’€';
    document.getElementById('ov-title').style.color='#ff5555';
    document.getElementById('ov-title').textContent='GAME OVER';
    document.getElementById('ov-sub').textContent='You scored:';
    document.getElementById('ov-score').textContent=score+' pts';
    document.getElementById('ov-btn').textContent='â†º PLAY AGAIN';
    document.getElementById('overlay').classList.add('show');
  }, 500);
}

function updateScore(){
  document.getElementById('sc').textContent=score;
  document.getElementById('hi').textContent=Math.max(score,best);
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  PARTICLES
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function spawnParticles(gx,gy,col,n=10){
  const cx=gx*SZ+SZ/2, cy=gy*SZ+SZ/2;
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2, sp=1+Math.random()*3;
    particles.push({x:cx,y:cy,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,r:2+Math.random()*4,life:1,col});
  }
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  RENDER
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function render() {
  ctx.clearRect(0,0,cv.width,cv.height);

  // Grid bg
  for(let x=0;x<COLS;x++) for(let y=0;y<ROWS;y++){
    ctx.fillStyle=(x+y)%2===0?'#0d0f16':'#0f1118';
    ctx.fillRect(x*SZ,y*SZ,SZ,SZ);
  }

  // Particles
  for(const p of particles){
    ctx.globalAlpha=p.life;
    ctx.fillStyle=p.col;
    ctx.beginPath(); ctx.arc(p.x,p.y,p.r*p.life,0,Math.PI*2); ctx.fill();
    p.x+=p.vx; p.y+=p.vy; p.vy+=0.1; p.life-=0.04;
  }
  particles=particles.filter(p=>p.life>0);
  ctx.globalAlpha=1;

  // Snake
  snake.forEach((seg,i)=>{
    const isHead=i===0;
    const t = i/snake.length;
    // Color gradient: bright green head â†’ darker tail
    const g = Math.floor(255*(1-t*0.5));
    const r = Math.floor(50*(t));
    ctx.fillStyle = isHead ? '#69ff47' : `rgb(${r},${g},30)`;

    const pad = isHead ? 1 : 2;
    const r2  = isHead ? 5 : 3;
    roundRect(ctx, seg.x*SZ+pad, seg.y*SZ+pad, SZ-pad*2, SZ-pad*2, r2);
    ctx.fill();

    // Head shine
    if(isHead){
      ctx.fillStyle='rgba(255,255,255,0.25)';
      roundRect(ctx, seg.x*SZ+pad+2, seg.y*SZ+pad+2, (SZ-pad*2)*0.5, (SZ-pad*2)*0.4, 3);
      ctx.fill();

      // Eyes
      const ex = seg.x*SZ+SZ/2;
      const ey = seg.y*SZ+SZ/2;
      const eyeOff = SZ*0.22;
      let e1x=ex-eyeOff, e1y=ey-eyeOff, e2x=ex+eyeOff, e2y=ey-eyeOff;
      if(dir.x===1){  e1x=ex+eyeOff; e1y=ey-eyeOff; e2x=ex+eyeOff; e2y=ey+eyeOff; }
      if(dir.x===-1){ e1x=ex-eyeOff; e1y=ey-eyeOff; e2x=ex-eyeOff; e2y=ey+eyeOff; }
      if(dir.y===1){  e1x=ex-eyeOff; e1y=ey+eyeOff; e2x=ex+eyeOff; e2y=ey+eyeOff; }
      ctx.fillStyle='#000';
      ctx.beginPath(); ctx.arc(e1x,e1y,1.8,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(e2x,e2y,1.8,0,Math.PI*2); ctx.fill();
      ctx.fillStyle='white';
      ctx.beginPath(); ctx.arc(e1x+.5,e1y-.5,.8,0,Math.PI*2); ctx.fill();
      ctx.beginPath(); ctx.arc(e2x+.5,e2y-.5,.8,0,Math.PI*2); ctx.fill();
    }
  });

  // Food
  if(food){
    ctx.font=`${SZ-2}px serif`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText(foodEmoji, food.x*SZ+SZ/2, food.y*SZ+SZ/2+1);
  }

  // Bonus (flashing star)
  if(bonus){
    const alpha = bonusTimer%8<4 ? 1 : 0.4;
    ctx.globalAlpha=alpha;
    ctx.font=`${SZ-2}px serif`;
    ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText('â­', bonus.x*SZ+SZ/2, bonus.y*SZ+SZ/2+1);
    ctx.globalAlpha=1;
  }

  ctx.textAlign='left'; ctx.textBaseline='alphabetic';
}

function roundRect(c,x,y,w,h,r){
  c.beginPath();
  c.moveTo(x+r,y); c.lineTo(x+w-r,y);
  c.quadraticCurveTo(x+w,y,x+w,y+r);
  c.lineTo(x+w,y+h-r);
  c.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  c.lineTo(x+r,y+h);
  c.quadraticCurveTo(x,y+h,x,y+h-r);
  c.lineTo(x,y+r);
  c.quadraticCurveTo(x,y,x+r,y);
  c.closePath();
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  INPUT
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
function setDir(x,y){
  if(state!=='playing') return;
  // Prevent reversing
  if(x!==0 && x===-dir.x) return;
  if(y!==0 && y===-dir.y) return;
  if(x===0&&y===0) return;
  nextDir={x,y};
}

// Keyboard
document.addEventListener('keydown',e=>{
  const m={'ArrowLeft':[-1,0],'ArrowRight':[1,0],'ArrowUp':[0,-1],'ArrowDown':[0,1]};
  if(m[e.key]){ e.preventDefault(); setDir(...m[e.key]); }
});

// Swipe
let tx=0,ty=0;
cv.addEventListener('touchstart',e=>{ tx=e.touches[0].clientX; ty=e.touches[0].clientY; },{passive:true});
cv.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx;
  const dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)<12&&Math.abs(dy)<12) return;
  if(Math.abs(dx)>Math.abs(dy)) setDir(dx>0?1:-1,0);
  else setDir(0,dy>0?1:-1);
},{passive:true});

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
//  INIT
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
best = parseInt(localStorage.getItem('snake_best')||'0');
document.getElementById('hi').textContent = best;
document.getElementById('overlay').classList.add('show');
render();
</script>
</body>
</html>
